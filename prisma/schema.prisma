generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  fullName         String
  role             String           @default("scout") // "scout" or "admin"
  unit             String?          // "jouwele", "mounjidet", "kechefe", "mourchidet", "jaramiz", "zaharat", "iyede"
  mustChangePassword Boolean        @default(true) @map("must_change_password")
  lastActiveAt     DateTime?        @map("last_active_at")
  tickets          Ticket[]
  scoutSettlements CashSettlement[] @relation("ScoutSettlements")
  adminSettlements CashSettlement[] @relation("AdminSettlements")
  createdAt        DateTime         @default(now())

  // Rovers camp portal fields
  roverProfile     RoverProfile?
  questCompletions QuestCompletion[]
  questSubmissions QuestSubmission[]
  bids             ShopItem[]       @relation("HighestBidder")
  purchases        ShopPurchase[]
}

model Team {
  id            String   @id // 'ARG', 'BRA', etc.
  name          String
  flagUrl       String
  totalWins     Int      @default(0)
  isEliminated  Boolean  @default(false)
  tickets       Ticket[]
  updatedAt     DateTime @updatedAt
}

model Ticket {
  id        Int      @id @default(autoincrement())
  scoutId   String?
  scout     Profile? @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  buyerName String
  buyerPhone String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  paymentStatus String @default("PAID")
  paymentMethod String @default("CASH")
  whishTransactionId String?
  cashSettled Boolean @default(false)
  winner      Winner?
}

model Winner {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  prizeName String
  drawnAt   DateTime @default(now())
}

model CashSettlement {
  id          Int      @id @default(autoincrement())
  scoutId     String
  scout       Profile  @relation("ScoutSettlements", fields: [scoutId], references: [id], onDelete: Cascade)
  adminId     String
  admin       Profile  @relation("AdminSettlements", fields: [adminId], references: [id], onDelete: Cascade)
  amount      Float
  ticketCount Int
  ticketIds   String   // Comma-separated list of ticket IDs for auditing
  createdAt   DateTime @default(now())
}

model WhatsAppLog {
  id        Int      @id @default(autoincrement())
  phone     String
  body      String
  status    String   // "SENT" or "FAILED"
  error     String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}

enum Faction {
  ALPHA
  BRAVO
}

enum VerificationType {
  DIGITAL_CODE
  LEADER_SIGN_OFF
}

enum QuestPhase {
  PRE_CAMP
  LIVE_CAMP
}

model RoverProfile {
  id           String   @id @default(uuid())
  profileId    String   @unique
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  roverCredits Int      @default(0) @map("rover_credits")
  faction      Faction?
  phoneNumber  String   @map("phone_number")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Quest {
  id                  String            @id @default(uuid())
  title               String
  description         String            // Markdown text
  clueHint            String?           @map("clue_hint")
  verificationType    VerificationType  @map("verification_type")
  encryptedAnswerHash String?           @map("encrypted_answer_hash")
  creditReward        Int               @map("credit_reward")
  isReleased          Boolean           @default(false) @map("is_released")
  isBlind             Boolean           @default(false) @map("is_blind")
  unlockedAtDate      DateTime          @map("unlocked_at_date")
  expiresAt           DateTime?         @map("expires_at")
  phase               QuestPhase
  completions         QuestCompletion[]
  submissions         QuestSubmission[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model QuestCompletion {
  id          String   @id @default(uuid())
  roverId     String   @map("rover_id")
  rover       Profile  @relation(fields: [roverId], references: [id], onDelete: Cascade)
  questId     String   @map("quest_id")
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  isVerified  Boolean  @default(true) @map("is_verified")
  completedAt DateTime @default(now()) @map("completed_at")

  @@unique([roverId, questId])
}

model QuestSubmission {
  id          String   @id @default(uuid())
  roverId     String   @map("rover_id")
  rover       Profile  @relation(fields: [roverId], references: [id], onDelete: Cascade)
  questId     String   @map("quest_id")
  quest       Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  answer      String
  submittedAt DateTime @default(now()) @map("submitted_at")
}

enum ShopItemType {
  FIXED_PRICE
  AUCTION
}

model ShopItem {
  id                String       @id @default(uuid())
  title             String
  description       String
  type              ShopItemType
  priceOrCurrentBid Int          @map("price_or_current_bid")
  highestBidderId   String?      @map("highest_bidder_id")
  highestBidder     Profile?     @relation("HighestBidder", fields: [highestBidderId], references: [id], onDelete: SetNull)
  isAvailable       Boolean      @default(true) @map("is_available")
  hintText          String?      @map("hint_text")  // Populated for quest hint items; admin sees this when delivering
  stock             Int          @default(0)
  purchases         ShopPurchase[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model GeoNode {
  id                 String   @id @default(uuid())
  name               String
  latitude           Float
  longitude          Float
  radiusMeters       Int      @default(20) @map("radius_meters")
  secretPasscode     String   @map("secret_passcode")
  controllingFaction Faction? @map("controlling_faction")
  isHotSpot          Boolean  @default(false) @map("is_hot_spot")
  isDecoy            Boolean  @default(false) @map("is_decoy")
  expiresAt          DateTime? @map("expires_at")
  shieldExpiresAt    DateTime? @map("shield_expires_at")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model NodeCheckIn {
  id        String   @id @default(uuid())
  nodeId    String   @map("node_id")
  roverId   String   @map("rover_id")
  faction   Faction  @map("faction")
  createdAt DateTime @default(now()) @map("created_at")
}

model ShopPurchase {
  id          String   @id @default(uuid())
  shopItemId  String   @map("shop_item_id")
  shopItem    ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Cascade)
  roverId     String   @map("rover_id")
  rover       Profile  @relation(fields: [roverId], references: [id], onDelete: Cascade)
  pricePaid   Int      @map("price_paid")
  isDelivered Boolean  @default(false) @map("is_delivered")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}
