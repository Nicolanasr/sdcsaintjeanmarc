generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  fullName         String
  role             String           @default("scout") // "scout" or "admin"
  unit             String?          // "jouwele", "mounjidet", "kechefe", "mourchidet", "jaramiz", "zaharat", "iyede"
  tickets          Ticket[]
  scoutSettlements CashSettlement[] @relation("ScoutSettlements")
  adminSettlements CashSettlement[] @relation("AdminSettlements")
  createdAt        DateTime         @default(now())
}

model Team {
  id            String   @id // 'ARG', 'BRA', etc.
  name          String
  flagUrl       String
  totalWins     Int      @default(0)
  isEliminated  Boolean  @default(false)
  tickets       Ticket[]
  updatedAt     DateTime @updatedAt
}

model Ticket {
  id        Int      @id @default(autoincrement())
  scoutId   String?
  scout     Profile? @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  buyerName String
  buyerPhone String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  paymentStatus String @default("PAID")
  paymentMethod String @default("CASH")
  whishTransactionId String?
  cashSettled Boolean @default(false)
  winner      Winner?
}

model Winner {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @unique
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  prizeName String
  drawnAt   DateTime @default(now())
}

model CashSettlement {
  id          Int      @id @default(autoincrement())
  scoutId     String
  scout       Profile  @relation("ScoutSettlements", fields: [scoutId], references: [id], onDelete: Cascade)
  adminId     String
  admin       Profile  @relation("AdminSettlements", fields: [adminId], references: [id], onDelete: Cascade)
  amount      Float
  ticketCount Int
  ticketIds   String   // Comma-separated list of ticket IDs for auditing
  createdAt   DateTime @default(now())
}

model WhatsAppLog {
  id        Int      @id @default(autoincrement())
  phone     String
  body      String
  status    String   // "SENT" or "FAILED"
  error     String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}
